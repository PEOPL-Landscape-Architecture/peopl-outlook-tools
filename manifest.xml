<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>71789634-9e4d-4a04-b3f5-125f49298ed7</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>PEOPL Landscape Architecture</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="PEOPL Email Templates"/>
  <Description DefaultValue="Insert editable email templates and swap words, phrases and paragraphs with dropdowns."/>
  <IconUrl DefaultValue="https://peopl-landscape-architecture.github.io/peopl-outlook-tools/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://peopl-landscape-architecture.github.io/peopl-outlook-tools/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://peopl-landscape-architecture.github.io/peopl-outlook-tools/"/>
  <AppDomains>
    <AppDomain>https://peopl-landscape-architecture.github.io</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://peopl-landscape-architecture.github.io/peopl-outlook-tools/src/taskpane.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="peoplTemplatesGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="peoplOpenTemplates">
                  <Label resid="ButtonLabel"/>
                  <Supertip>
                    <Title resid="SupertipTitle"/>
                    <Description resid="SupertipDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16"/>
                    <bt:Image size="32" resid="Icon.32"/>
                    <bt:Image size="80" resid="Icon.80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16" DefaultValue="https://peopl-landscape-architecture.github.io/peopl-outlook-tools/assets/icon-16.png"/>
        <bt:Image id="Icon.32" DefaultValue="https://peopl-landscape-architecture.github.io/peopl-outlook-tools/assets/icon-32.png"/>
        <bt:Image id="Icon.80" DefaultValue="https://peopl-landscape-architecture.github.io/peopl-outlook-tools/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://peopl-landscape-architecture.github.io/peopl-outlook-tools/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://peopl-landscape-architecture.github.io/peopl-outlook-tools/src/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="PEOPL"/>
        <bt:String id="ButtonLabel" DefaultValue="Templates"/>
        <bt:String id="SupertipTitle" DefaultValue="Email templates"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="SupertipDesc" DefaultValue="Insert an email template and swap words, phrases and paragraphs with dropdowns."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
