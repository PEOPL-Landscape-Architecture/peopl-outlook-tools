{
  "manifest_version": 3,
  "name": "PEOPL Email Templates",
  "version": "1.3.0",
  "description": "Pick an email template and swap words, phrases and paragraphs with dropdowns, then fill the Outlook compose window. Opens in its own resizable window; includes a built-in template editor.",
  "action": {
    "default_title": "PEOPL Email Templates (Alt+Shift+E)",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": { "service_worker": "sw.js" },
  "options_page": "editor.html",
  "commands": {
    "open_templates": {
      "suggested_key": { "default": "Alt+Shift+E" },
      "description": "Open PEOPL Email Templates"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["scripting", "clipboardWrite", "storage"],
  "host_permissions": [
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "https://outlook.live.com/*",
    "https://outlook.cloud.microsoft/*",
    "https://*.outlook.com/*"
  ]
}
